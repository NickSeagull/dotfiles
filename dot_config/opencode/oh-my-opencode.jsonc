{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",

  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-6",
      "ultrawork": { "model": "anthropic/claude-opus-4-6", "variant": "max" },
    },
    "librarian": { "model": "anthropic/claude-haiku-4-5" },
    "explore": { "model": "anthropic/claude-haiku-4-5" },
    "oracle": { "model": "anthropic/claude-opus-4-6", "variant": "high" },
    "prometheus": {
      "prompt_append": "Leverage deep & quick agents heavily, always in parallel.",
    },
    "metis": { "model": "openai/gpt-5.3-codex", "variant": "medium" },
    "momus": { "model": "openai/gpt-5.3-codex", "variant": "high" },
  },

  "categories": {
    "quick": { "model": "anthropic/claude-haiku-4-5" },
    "unspecified-low": { "model": "anthropic/claude-sonnet-4-5" },
    "unspecified-high": {
      "model": "anthropic/claude-sonnet-4-5",
      "variant": "max",
    },
    "writing": { "model": "anthropic/claude-sonnet-4-5" },
    "visual-engineering": {
      "model": "anthropic/claude-sonnet-4-5",
      "variant": "high",
    },
    "git": {
      "model": "anthropic/claude-haiku-4-5",
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, clear messages, and safe operations.",
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
      "description": "Genuinely hard, logic-heavy tasks requiring deep reasoning",
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "high",
      "description": "Goal-oriented autonomous problem-solving with thorough research",
    },
    "artistry": {
      "model": "openai/gpt-5.3-codex",
      "variant": "high",
      "description": "Complex problems requiring unconventional, creative approaches",
    },
  },

  "background_task": {
    "providerConcurrency": { "anthropic": 5, "openai": 3 },
    "modelConcurrency": {
      "anthropic/claude-opus-4-6": 2,
      "anthropic/claude-haiku-4-5": 20,
      "openai/gpt-5.3-codex": 2,
    },
  },

  "experimental": { "aggressive_truncation": true, "task_system": true },
  "tmux": { "enabled": false },
}
