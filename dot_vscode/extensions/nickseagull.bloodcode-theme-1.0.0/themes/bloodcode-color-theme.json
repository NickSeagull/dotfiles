  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#a3918c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation comments",
      "scope": [
        "comment.block.documentation",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#a3918c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#c21c28"
      }
    },
    {
      "name": "String escape characters",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#ff2e3a"
      }
    },
    {
      "name": "Template string interpolation",
      "scope": [
        "punctuation.definition.template-expression",
        "string.template punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#ff2e3a"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.binary"
      ],
      "settings": {
        "foreground": "#ffa83d"
      }
    },
    {
      "name": "Booleans and constants",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#ffa83d"
      }
    },
    {
      "name": "Other constants",
      "scope": [
        "constant.other",
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#ffa83d"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#ff70c7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword operators",
      "scope": [
        "keyword.operator.expression",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.logical",
        "keyword.operator.wordlike"
      ],
      "settings": {
        "foreground": "#ff70c7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.bitwise",
        "keyword.operator.ternary",
        "keyword.operator.type",
        "keyword.operator.spread",
        "keyword.operator.rest"
      ],
      "settings": {
        "foreground": "#f6c524",
        "fontStyle": ""
      }
    },
    {
      "name": "Import/Export/Return",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.default"
      ],
      "settings": {
        "foreground": "#ffaf00"
      }
    },
    {
      "name": "Exception keywords",
      "scope": [
        "keyword.control.trycatch",
        "keyword.control.exception"
      ],
      "settings": {
        "foreground": "#bf4bff"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#30e5ff"
      }
    },
    {
      "name": "Function calls",
      "scope": [
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#30e5ff"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin",
        "support.function.magic"
      ],
      "settings": {
        "foreground": "#bf4bff"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#ff6270"
      }
    },
    {
      "name": "Variable parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#ff6270",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Built-in variables",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#bf4bff"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#ff6270"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ffe657"
      }
    },
    {
      "name": "Built-in types",
      "scope": [
        "support.type.builtin",
        "support.type.primitive",
        "keyword.type"
      ],
      "settings": {
        "foreground": "#ffe657"
      }
    },
    {
      "name": "Type parameters / generics",
      "scope": [
        "entity.name.type.parameter"
      ],
      "settings": {
        "foreground": "#ffe657"
      }
    },
    {
      "name": "Interfaces",
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#ffe657"
      }
    },
    {
      "name": "Enums",
      "scope": [
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#ffe657"
      }
    },
    {
      "name": "Storage modifiers",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ffe657"
      }
    },
    {
      "name": "Function storage (function, class, let, const, var)",
      "scope": [
        "storage.type.function",
        "storage.type.class"
      ],
      "settings": {
        "foreground": "#ff70c7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Namespaces and modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.other.module",
        "entity.name.type.module"
      ],
      "settings": {
        "foreground": "#ffaf00"
      }
    },
    {
      "name": "Constructors",
      "scope": [
        "entity.name.function.constructor",
        "meta.method.declaration storage.type"
      ],
      "settings": {
        "foreground": "#ffe657"
      }
    },
    {
      "name": "Preprocessor / Macros",
      "scope": [
        "keyword.control.directive",
        "keyword.control.preprocessor",
        "entity.name.function.preprocessor",
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#ffaf00"
      }
    },
    {
      "name": "Decorators / Annotations / Attributes",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator",
        "storage.type.annotation",
        "meta.attribute"
      ],
      "settings": {
        "foreground": "#ffaf00"
      }
    },
    {
      "name": "Punctuation — brackets",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "punctuation.definition.arguments",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#a3918c"
      }
    },
    {
      "name": "Punctuation — delimiters",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#a3918c"
      }
    },
    {
      "name": "Special punctuation",
      "scope": [
        "punctuation.definition.interpolation",
        "punctuation.section.interpolation",
        "punctuation.definition.typeparameters"
      ],
      "settings": {
        "foreground": "#ff2e3a"
      }
    },
    {
      "name": "Tags (HTML/XML)",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#ffe657"
      }
    },
    {
      "name": "Tag brackets",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
