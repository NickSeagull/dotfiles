      ],
      "settings": {
        "foreground": "#c21c28"
      }
    },
    {
      "name": "Markdown quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#a3918c",
        "fontStyle": "italic"
      }
