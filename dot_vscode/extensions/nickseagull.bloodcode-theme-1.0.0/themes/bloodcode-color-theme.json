    {
      "name": "Changed (diff)",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#f6c524"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
